# По умолчанию (если переменные не заданы) — продакшен из Swagger:
# https://oleg-forum-site.matthew-0203.ru/api/docs
#
# Локальный pyForum:
# VITE_API_ROOT_ORIGIN=http://localhost:8000
# VITE_API_BASE_URL=http://localhost:8000/api/v1
#
# Локальный Vite `npm run dev` без CORS: относительный путь + прокси в vite.config.ts
# (по умолчанию на oleg-forum-site…; свой бэкенд: VITE_DEV_PROXY_TARGET=http://127.0.0.1:8000 при запуске Vite).
# VITE_API_BASE_URL=/api/v1

VITE_API_ROOT_ORIGIN=https://oleg-forum-site.matthew-0203.ru
VITE_API_BASE_URL=https://oleg-forum-site.matthew-0203.ru/api/v1
VITE_API_BEARER_TOKEN=paste_your_access_token_here

# Статические файлы (не в Swagger): без JWT.
#
# Вложения сообщения (пост или комментарий — id того же сообщения в URL):
# https://ХОСТ/static/messages/{message_id}/{filename}
# Пример: …/static/messages/7e8dcab2-…/227f486c-….png
#
# Аватар пользователя:
# https://ХОСТ/static/avatars/{user_id}/{filename}
# Пример: …/static/avatars/681b2474-…/2ddd098e-….jpg
# (поле UserResponse.avatar_path может быть относительным путём — склеивается с VITE_STATIC_ORIGIN)
#
# VITE_STATIC_ORIGIN=https://oleg-forum-site.matthew-0203.ru
#
# Переопределение шаблонов (encodeURIComponent подставляется в {…}):
# VITE_MESSAGE_STATIC_TEMPLATE=/static/messages/{message_id}/{filename}
# VITE_AVATAR_STATIC_TEMPLATE=/static/avatars/{user_id}/{filename}
